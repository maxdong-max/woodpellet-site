p {
    margin-bottom:10px;
}
.entry-summary-items > .ct-product-divider[data-id="divider_1"] {
    --product-element-spacing: 10px;
}
.product[class*=gallery] .entry-summary-items>* {
    margin-bottom:10px;
}
.product>.woocommerce-tabs {
    padding-top: 0px;
}

@media (max-width: 999.98px){
[data-prefix="product"] [class*="ct-container"] > article[class*="post"] {
    --theme-boxed-content-spacing: 10px;
}
}
@media (max-width: 750px){
	.elementor-element-31eab2c, .slick-slider{ max-height:250px;}
[data-prefix="product"] [class*="ct-container"] > article[class*="post"] {
    --theme-boxed-content-spacing: 5px;
}
.wpr-template-popup{display:none !important;}
	}

#header{
	  position: sticky;
    z-index: 999999;
    top: 0;
    width: 100%;
}
.slick-slider{ max-height: 710px;}
.cky-revisit-bottom-left{bottom:70px !important;}
.slick-dots{width:100% !important;}

#wpforms-form-4559 input{color:#000 !important;}
.elementor-image-carousel-wrapper{max-height:750px;}
.ct-toggle-dropdown-desktop{--theme-icon-size:14px;margin-left:10px;}
[data-header*=type-1] .ct-header [data-id=menu] #menu-item-1630  .sub-menu,[data-header*=type-1] .ct-header [data-id=menu] #menu-item-1464  .sub-menu{--dropdown-width: 520px !important;}
.ct-hidden-md .ct-sidebar{border-top: 5px solid #00a381!important;}
.ct-hidden-md .ct-sidebar h2,.elementor-element .ct-widget h2{border-radius:6px;}
.elementor-element .ct-widget:not(:last-child) {
    margin-bottom:20px;
}
.wpforms-container ul, .wpforms-container ul li{list-style-type: none !important;display: inline-block;padding-right: 20px;}
.wpforms-container .wpforms-field{    padding: 5px 0 !important;}
.wpforms-container .wpforms-form .wpforms-field-content>.wpforms-field-row h4{border-bottom:1px solid #edeff2; padding-bottom:3px; padding-top:10px;}
#wpforms-submit-11351{width:100%;}
.wpforms-field-label{margin: 0;}
#wpforms-submit-4559, #wpforms-submit-4565{background:#0AEAF4;margin: 0 auto;display: block;}

[data-products] .product{
border: 1px solid #eee;
border-radius: 10px;
padding: 5px;
}
.entry-meta .meta-categories>a{pointer-events: none; cursor: not-allowed;}
		</style>
